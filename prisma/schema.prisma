generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  mensaje   String
  tipo      String?
  status    String   @default("new")
  source    String   @default("landing")
  createdAt DateTime @default(now())
}
