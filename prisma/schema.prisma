generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id             String    @id @default(cuid())
  email          String
  mensaje        String
  tipo           String?
  status         String    @default("new")
  source         String    @default("landing")
  createdAt      DateTime  @default(now())
  aiResponse     String?
  aiResponseAt   DateTime?
  aiError        String?
  score          Int       @default(0)
  temperature    String    @default("cold")
}

enum EventType {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_UPDATED
}

model Event {
  id        String    @id @default(cuid())
  type      EventType
  entity    String?
  entityId  String?
  payload   Json?
  createdAt DateTime  @default(now())

  @@index([type])
  @@index([entityId])
  @@index([createdAt])
}
